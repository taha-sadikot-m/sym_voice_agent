# Copy to .env or .env.local (both are loaded; .env.local wins on conflict)
# LiveKit Cloud (https://cloud.livekit.io)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
VOICE_AGENT_NAME=sym-voice-agent

# Concurrency (optional — for multiple simultaneous voice sessions)
# VOICE_AGENT_NUM_IDLE_PROCESSES=2
# VOICE_AGENT_LOAD_THRESHOLD=0.75

# Deepgram (STT + TTS)
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_STT_LANGUAGE=en-IN
DEEPGRAM_TTS_MODEL=aura-2-draco-en

# Google Gemini (must match backend model)
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Django backend (for session persistence / evaluation)
DJANGO_API_URL=http://127.0.0.1:8000/api/v1
